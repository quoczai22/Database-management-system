<Page x:Class="QuanLyLinhKienMayTinh.Views.LinhKienView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="1000"
      Title="Linh Kiện">

    <Page.Resources>
        <!-- ===== SHARED STYLE SYSTEM ===== -->
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1a202c"/>
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="38,9,12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2d3748"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3f51b5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#3f51b5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303f9f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1a237e"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#43a047"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2e7d32"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#e53935"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b71c1c"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#fb8c00"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e65100"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#f0f2ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#3f51b5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#5c6bc0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#e8eaf6"/>
                    <Setter Property="Foreground" Value="#1a202c"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f5f7ff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Linh Kiện" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Quản lý danh sách linh kiện máy tính" Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" Content="＋  Thêm linh kiện"
                    Style="{StaticResource SuccessBtnStyle}"
                    Padding="16,10"
                    Command="{Binding ThemLinhKienCommand}"/>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="14,10"
                BorderBrush="#e2e8f0" BorderThickness="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding TimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0,0,0"
                               IsHitTestVisible="False" Foreground="#a0aec0"/>
                </Grid>

                <!-- Filter ComboBox -->
                <ComboBox Grid.Column="1" Margin="0,0,12,0"
                          Padding="10,8" FontSize="13"
                          BorderBrush="#e2e8f0"
                          ItemsSource="{Binding DanhSachLoai}"
                          SelectedItem="{Binding LoaiChon}"
                          DisplayMemberPath="TenLoai"/>

                <!-- Refresh -->
                <Button Grid.Column="2" Content="↺  Làm mới"
                        Style="{StaticResource PrimaryBtnStyle}"
                        Command="{Binding LamMoiCommand}"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Background="White" CornerRadius="10"
                BorderBrush="#e2e8f0" BorderThickness="1" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding DanhSachLinhKienView}"
                      SelectedItem="{Binding LinhKienChon}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#edf2f7"
                      RowBackground="White" AlternatingRowBackground="#f9fafb"
                      FontSize="13" BorderThickness="0"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã LK" Binding="{Binding MaLk}" Width="90"/>
                    <DataGridTextColumn Header="Tên linh kiện" Binding="{Binding TenLk}" Width="*"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding TenLoai}" Width="130"/>
                    <DataGridTextColumn Header="NSX" Binding="{Binding Nsx}" Width="130"/>
                    <DataGridTextColumn Header="ĐVT" Binding="{Binding Dvt}" Width="80"/>
                    <DataGridTextColumn Header="Bảo hành" Binding="{Binding Tgbh}" Width="90"/>
                    <DataGridTextColumn Header="Ngày SX" Binding="{Binding NgaySx, StringFormat=dd/MM/yyyy}" Width="110"/>
                    <DataGridTemplateColumn Header="Thao tác" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✏️" Style="{StaticResource IconBtnStyle}"
                                            ToolTip="Chỉnh sửa" Margin="2"
                                            Command="{Binding DataContext.SuaLinhKienCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="🗑️" Style="{StaticResource IconBtnStyle}"
                                            ToolTip="Xóa" Margin="2"
                                            Command="{Binding DataContext.XoaLinhKienCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
