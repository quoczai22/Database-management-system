<Window x:Class="QuanLyLinhKienMayTinh.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Quản Lý Linh Kiện Máy Tính"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundColor}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="menuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#ffffff18"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#ffffff28"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="menuButtonActive" TargetType="Button" BasedOn="{StaticResource menuButton}">
            <Setter Property="Background" Value="#ffffff22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="menuButtonIcon" TargetType="Icon:PackIconMaterial">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="topButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="textboxSearch" TargetType="TextBox">
            <Setter Property="Padding" Value="40,10,40,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarAnimationStyle" TargetType="Border">
            <Setter Property="Width" Value="64"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="Open">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" To="220" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Width" To="70" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="SidebarBorder" Grid.Column="0"
                Background="{DynamicResource WindowBgColor}" CornerRadius="0,16,16,0" Width="70"
                ClipToBounds="True" Panel.ZIndex="10">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SidebarAnimationStyle}">
                    <Setter Property="Tag" Value="Close"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=btnHoverMenu}" Value="True">
                            <Setter Property="Tag" Value="Open"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Tag" Value="Open"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,20">
                    <Border Width="44" Height="44" CornerRadius="12" Background="Aqua" 
                            HorizontalAlignment="Center" Margin="0,0,0,14">
                        <TextBlock FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="/Images/avatar.png" Width="24" Height="24"/>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding CurrentUsername}" Foreground="White"
                               FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Margin="8,0"/>
                    <TextBlock x:Name="txtQuyen" Foreground="#9fa8da"
                               FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>

                <Button DockPanel.Dock="Bottom" Style="{StaticResource menuButton}"
                        Command="{Binding LogOutCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                        Margin="8,0,8,16">
                    <StackPanel Orientation="Horizontal">
                        <Icon:PackIconMaterial Kind="Logout" Style="{StaticResource menuButtonIcon}" Foreground="#ef9a9a"/>
                        <TextBlock Text="Đăng xuất" VerticalAlignment="Center" Foreground="#ef9a9a"/>
                    </StackPanel>
                </Button>

                <Rectangle DockPanel.Dock="Bottom" Height="1" Fill="{DynamicResource BackgroundColor2}" Margin="16,0,16,8"/>

                <StackPanel Margin="0,4,0,0">
                    <Button Style="{StaticResource menuButton}" Click="btnDashboard_Click" Visibility="{Binding MenuDashboardVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="ViewDashboardOutline" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Trang Chủ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnLinhKien_Click" Visibility="{Binding MenuLinhKienVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="Memory" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Linh Kiện" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnLoaiLK_Click" Visibility="{Binding MenuLoaiLKVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="TagMultiple" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Loại Linh Kiện" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnKhachHang_Click" Visibility="{Binding MenuKhachHangVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="AccountGroupOutline" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Khách Hàng" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnNhanVien_Click" Visibility="{Binding MenuNhanVienVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="AccountTie" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Nhân Viên" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnHoaDon_Click" Visibility="{Binding MenuHoaDonVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="ReceiptOutline" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Hóa Đơn" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource menuButton}" Click="btnBaoMat_Click" Visibility="{Binding MenuBaoMatVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="Tools" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Bảo Mật" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource menuButton}" Click="btnTaiKhoan_Click" Visibility="{Binding MenuTaiKhoanVisibility}">
                        <StackPanel Orientation="Horizontal">
                            <Icon:PackIconMaterial Kind="AccountKeyOutline" Style="{StaticResource menuButtonIcon}"/>
                            <TextBlock Text="Cấp Tài Khoản" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="24,16,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="2"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">

                    <Button Style="{StaticResource topButton}" Margin="0,0,8,0" 
            Command="{Binding ToggleThemeCommand}" 
            ToolTip="Đổi giao diện Sáng/Tối">
                        <Icon:PackIconMaterial Kind="ThemeLightDark" Width="16" Height="16"/>
                    </Button>

                    <Button Style="{StaticResource topButton}" Margin="0,0,8,0" Command="{Binding ThongBaoCommand}">
                        <Icon:PackIconMaterial Kind="BellOutline" Width="16" Height="16"/>
                    </Button>

                    <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource ButtonColor}">
                        <TextBlock Text="{Binding CurrentUsername[0]}" FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource ButtonTextColor}" 
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource BackgroundColor}" CornerRadius="16" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.07" Color="#000000"/>
                </Border.Effect>
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
            </Border>
            
        </Grid>
    </Grid>
</Window>