<Window x:Class="QuanLyLinhKienMayTinh.Views.ThemSuaLoaiLinhKienDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông Tin Loại Linh Kiện"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundColor2}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ButtonColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock x:Name="TitleText" Text="Thêm Loại Linh Kiện" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource MainTextColor}" Margin="0,0,0,20"/>

        <TextBlock Text="Mã loại *" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtMaLoai" Style="{StaticResource InputStyle}" Margin="0,0,0,4"
                 MaxLength="3"/>
        <TextBlock x:Name="TxtMaLoaiHint" Text="Nhập mã tối đa 3 ký tự, ví dụ: MOU, RAM, CPU..."
                   FontSize="11" Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,14"/>

        <TextBlock Text="Tên loại linh kiện *" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtTenLoai" Style="{StaticResource InputStyle}" Margin="0,0,0,14"/>

        <TextBlock Text="Mô tả" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtMoTa" Style="{StaticResource InputStyle}" Margin="0,0,0,24"
                 TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto"
                 AcceptsReturn="True" VerticalContentAlignment="Top"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Style="{StaticResource CancelBtnStyle}"
                    Margin="0,0,10,0" Click="BtnHuy_Click"/>
            <Button x:Name="BtnLuu" Content="Lưu" Style="{StaticResource PrimaryBtnStyle}"
                    Click="BtnLuu_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
