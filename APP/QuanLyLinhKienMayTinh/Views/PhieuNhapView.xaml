<Page x:Class="QuanLyLinhKienMayTinh.Views.PhieuNhapView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="1000"
      Title="Phiếu Nhập Kho"
      Background="{DynamicResource BackgroundColor}">

    <Page.Resources>
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
        </Style>
        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextColor}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="38,9,12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#e53935"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#e53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b71c1c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SuccessBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#43a047"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2e7d32"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Phiếu Nhập Kho" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Quản lý danh sách phiếu nhập linh kiện" Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" Content="＋  Tạo phiếu nhập mới"
                    Style="{StaticResource SuccessBtnStyle}" Padding="16,10"
                    Command="{Binding TaoPhieuNhapMoiCommand}"/>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundColor}" CornerRadius="10" Padding="14,10"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding TuKhoanTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0,0,0"
                               IsHitTestVisible="False" Foreground="{DynamicResource SubTextColor}"/>
                </Grid>
                <DatePicker Grid.Column="1" Margin="0,0,10,0" Foreground="{DynamicResource MainTextColor}" Background="Transparent"
                            SelectedDate="{Binding TuNgay}" FontSize="13"/>
                <DatePicker Grid.Column="2" Margin="0,0,10,0" Foreground="{DynamicResource MainTextColor}" Background="Transparent"
                            SelectedDate="{Binding DenNgay}" FontSize="13"/>
                <Button Grid.Column="3" Content="Lọc"
                        Style="{StaticResource PrimaryBtnStyle}"
                        Command="{Binding LocPhieuNhapCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BackgroundColor}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,0,12,0"
                    ClipToBounds="True">
                <DataGrid ItemsSource="{Binding DanhSachPhieuNhap}"
                          SelectedItem="{Binding PhieuNhapChon}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                          RowBackground="{DynamicResource BackgroundColor2}" AlternatingRowBackground="{DynamicResource BackgroundColor}"
                          FontSize="13" BorderThickness="0" SelectionMode="Single" Margin="3">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã PN" Binding="{Binding MaPN}" Width="100"/>
                        <DataGridTextColumn Header="Nhân viên nhập" Binding="{Binding TenNhanVien}" Width="*"/>
                        <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhap, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Tổng tiền nhập" Binding="{Binding TongTien, StringFormat={}{0:N0} ₫}" Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#e53935"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource BackgroundColor}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SecondaryBgColor}" Padding="16,12"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" CornerRadius="2" Background="#e53935" Margin="0,2,10,2"/>
                            <TextBlock Text="Chi Tiết Phiếu Nhập" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding ChuaChonPhieuVisibility}">
                        <TextBlock Text="📦" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Chọn phiếu nhập để xem chi tiết"
                                   FontSize="13" Foreground="{DynamicResource SubTextColor}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Nội dung chi tiết -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16" Visibility="{Binding ChiTietVisibility}">

                            <Border Background="{DynamicResource SecondaryBgColor}" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Mã phiếu nhập" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.MaPN}"
                                                   HorizontalAlignment="Right" FontSize="13"
                                                   FontWeight="Bold" Foreground="#e53935"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Ngày nhập kho" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.NgayNhap, StringFormat=dd/MM/yyyy HH:mm}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Người thực hiện" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.TenNhanVien}"
                                                   HorizontalAlignment="Right" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="NHÀ CUNG CẤP" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Tên nhà cung cấp" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.TenNhaCungCap}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Số điện thoại" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.SoDienThoaiNCC}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="LINH KIỆN ĐÃ NHẬP" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,8"/>
                            <DataGrid ItemsSource="{Binding ChiTietLinhKienNhap}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                                      BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                                      FontSize="12" Margin="0,0,0,14" Foreground="{DynamicResource MainTextColor}"
                                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource SecondaryBgColor}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên linh kiện" Binding="{Binding TenLinhKien}" Width="*"/>
                                    <DataGridTextColumn Header="SL" Binding="{Binding SoLuongNhap}" Width="40"/>
                                    <DataGridTextColumn Header="Đơn giá nhập" Binding="{Binding DonGiaNhap, StringFormat={}{0:N0}}" Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,4,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="{DynamicResource SecondaryBgColor}" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Tổng số lượng" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.TongSoLuong, StringFormat={}{0} sản phẩm}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Separator Background="{DynamicResource BorderColor}" Margin="0,4"/>
                                    <Grid>
                                        <TextBlock Text="Tổng chi phí" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                                        <TextBlock Text="{Binding PhieuNhapChon.TongTien, StringFormat={}{0:N0} ₫}"
                                                   HorizontalAlignment="Right" FontSize="15"
                                                   FontWeight="Bold" Foreground="#e53935"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{DynamicResource SecondaryBgColor}" Padding="12"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Visibility="{Binding ChiTietVisibility}" CornerRadius="0,0,10,10">
                        <WrapPanel HorizontalAlignment="Center">
                            <Button Content="🖨️ In phiếu" Style="{StaticResource PrimaryBtnStyle}"
                                    Command="{Binding InPhieuNhapCommand}" Margin="4" Padding="12,8"/>
                            <Button Content="💾 Lưu Excel" Style="{StaticResource SuccessBtnStyle}"
                                    Command="{Binding LuuPhieuNhapCommand}" Margin="4" Padding="12,8"/>
                            <Button Content="🗑️ Xóa phiếu" Style="{StaticResource DangerBtnStyle}"
                                    Command="{Binding XoaPhieuNhapCommand}" Margin="4" Padding="12,8"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource BackgroundColor}" CornerRadius="10" Padding="16,12"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,12,0,0">
            <UniformGrid Columns="4">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource SecondaryBgColor}" Margin="0,0,10,0">
                        <TextBlock Text="📦" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TongSoPhieuNhap, StringFormat={}{0} phiếu}"
                                   FontSize="13" FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Text="Tổng phiếu nhập kho" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#ffebee" Margin="0,0,10,0">
                        <TextBlock Text="💸" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TongChiPhiNhap, StringFormat={}{0:N0} ₫}"
                                   FontSize="13" FontWeight="Bold" Foreground="#e53935"/>
                        <TextBlock Text="Tổng chi phí nhập hàng" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#e3f2fd" Margin="0,0,10,0">
                        <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TongSoLuongLinhKienNhap, StringFormat={}{0} sản phẩm}"
                                   FontSize="13" FontWeight="Bold" Foreground="#2196f3"/>
                        <TextBlock Text="Linh kiện nhập kho" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#e8f5e9" Margin="0,0,10,0">
                        <TextBlock Text="📅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SoPhieuNhapThangNay, StringFormat={}{0} phiếu}"
                                   FontSize="13" FontWeight="Bold" Foreground="#43a047"/>
                        <TextBlock Text="Phiếu nhập tháng này" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
            </UniformGrid>
        </Border>
    </Grid>
</Page>
