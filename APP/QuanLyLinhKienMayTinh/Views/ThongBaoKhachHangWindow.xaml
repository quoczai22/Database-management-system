<Window x:Class="QuanLyLinhKienMayTinh.Views.ThongBaoKhachHangWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyLinhKienMayTinh.Views"
        mc:Ignorable="d"
        Title="ThongBaoKhachHangWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="CẢNH BÁO: DANH SÁCH HÓA ĐƠN CHƯA THANH TOÁN" 
                   Foreground="Red" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <DataGrid x:Name="dgKhachNo" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" HeadersVisibility="Column" 
                  CanUserAddRows="False" AlternatingRowBackground="#f9f9f9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã HĐ" Binding="{Binding MaHD}" Width="80"/>
                <DataGridTextColumn Header="Khách Hàng" Binding="{Binding TenKH}" Width="*"/>
                <DataGridTextColumn Header="SĐT" Binding="{Binding SDT}" Width="120"/>
                <DataGridTextColumn Header="Ngày Lập" Binding="{Binding NgayLap, StringFormat=dd/MM/yyyy}" Width="100"/>
                <DataGridTextColumn Header="Số Tiền Nợ" Binding="{Binding SoTienNo, StringFormat={}{0:N0} đ}" Width="120" Foreground="Red" FontWeight="Bold"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
