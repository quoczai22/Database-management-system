<Window x:Class="QuanLyLinhKienMayTinh.Views.MomoPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thanh toán MoMo"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}">

    <Window.Resources>
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Tiêu đề -->
        <TextBlock Text="Thanh toán qua MoMo" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource MainTextColor}" Margin="0,0,0,6"/>

        <!-- Thông tin hóa đơn -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Hóa đơn: " FontSize="13"
                       Foreground="{DynamicResource MainTextColor}" Opacity="0.6"/>
            <TextBlock x:Name="txtMaHD" Text="#HD001" FontSize="13"
                       FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
            <TextBlock Text="  —  Tổng tiền: " FontSize="13"
                       Foreground="{DynamicResource MainTextColor}" Opacity="0.6"/>
            <TextBlock x:Name="txtSoTien" Text="0 ₫" FontSize="13"
                       FontWeight="Bold" Foreground="#D82D8B"/>
        </StackPanel>

        <!-- Khung QR -->
        <Border Background="{DynamicResource BackgroundColor2}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1" CornerRadius="10"
                Padding="20" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Center">

                <!-- Logo MoMo nhỏ -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <Border Width="28" Height="28" CornerRadius="6">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#AE2070" Offset="0"/>
                                <GradientStop Color="#D82D8B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="M" FontSize="16" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="MoMo" FontSize="16" FontWeight="Bold"
                               Foreground="#D82D8B" Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Ảnh QR + Loading overlay + Success panel -->
                <Grid Width="220" Height="220" Margin="0,0,0,12">
                    <Image x:Name="imgQRCode" Width="220" Height="220" Stretch="Uniform"/>

                    <Border x:Name="loadingOverlay"
                            Background="{DynamicResource BackgroundColor2}"
                            CornerRadius="8" Width="220" Height="220">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⏳" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="Đang tạo mã QR..." FontSize="13"
                                       Foreground="{DynamicResource MainTextColor}"
                                       Opacity="0.5" Margin="0,8,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Success panel -->
                    <StackPanel x:Name="successPanel"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <Grid Width="100" Height="100" HorizontalAlignment="Center">
                            <Ellipse Width="100" Height="100" Fill="#00C853"/>
                            <TextBlock Text="✓"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Thanh toán thành công!"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#00C853"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                        <TextBlock x:Name="txtSuccessAmount"
                                   FontSize="11"
                                   Foreground="{DynamicResource MainTextColor}"
                                   Opacity="0.7"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Fail panel -->
                    <StackPanel x:Name="failPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">       
                        <Grid Width="100" Height="100" HorizontalAlignment="Center">
                            <Ellipse Width="100" Height="100" Fill="#FF4744"/>
                            <TextBlock Text="✕"
                               FontSize="56"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Thanh toán thất bại!"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#FF4744"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                        <TextBlock x:Name="txtFailReason"
                           FontSize="11"
                           Foreground="{DynamicResource MainTextColor}"
                           Opacity="0.7"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Mở app MoMo và quét mã để thanh toán"
                           FontSize="13" HorizontalAlignment="Center"
                           Foreground="{DynamicResource MainTextColor}" Opacity="0.7"/>
                <TextBlock x:Name="txtCountdown"
                           Text="Mã QR có hiệu lực trong 60 giây"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="{DynamicResource MainTextColor}"
                           Opacity="0.4" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Trạng thái -->
        <Border Background="{DynamicResource BackgroundColor2}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse x:Name="statusDot" Width="10" Height="10"
                         Fill="#FFA500" VerticalAlignment="Center">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.2" Duration="0:0:0.8"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock x:Name="txtStatus" Text="Đang chờ thanh toán..."
                           FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource MainTextColor}"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Nút -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="🔄  Làm mới" Style="{StaticResource CancelBtnStyle}"
                    Margin="0,0,10,0" Click="BtnRefresh_Click"/>
            <Button Content="Đóng" Style="{StaticResource PrimaryBtnStyle}"
                    Click="BtnDong_Click"/>
        </StackPanel>

    </StackPanel>
</Window>