<Window x:Class="QuanLyLinhKienMayTinh.Views.ThemSuaLinhKienDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông Tin Linh Kiện"
        Width="500" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundColor}">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundColor2}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ButtonColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock x:Name="TitleText" Text="Thêm Linh Kiện" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource MainTextColor}" Margin="0,0,0,20"/>

        <!-- Row 1: Mã LK -->
        <TextBlock Text="Mã linh kiện *" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtMaLk" Style="{StaticResource InputStyle}" Margin="0,0,0,4"
                 MaxLength="6"/>
        <TextBlock x:Name="TxtMaLkHint" Text="Nhập mã tối đa 6 ký tự, ví dụ: MOU001, RAM001, CPU001..."
                   FontSize="11" Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,14"/>

        <!-- Row 2: Tên LK -->
        <TextBlock Text="Tên linh kiện *" Style="{StaticResource LabelStyle}"/>
        <TextBox x:Name="TxtTenLk" Style="{StaticResource InputStyle}" Margin="0,0,0,14"/>

        <!-- Row 3: Loại và NSX trên cùng dòng -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Loại linh kiện *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CboLoai" Padding="10,8" FontSize="13"
                          Background="{DynamicResource BackgroundColor2}"
                          Foreground="{DynamicResource MainTextColor}"
                          BorderBrush="{DynamicResource BorderColor}"
                          DisplayMemberPath="TenLoai"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Nhà sản xuất *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CboNsx" Padding="10,8" FontSize="13"
                          Background="{DynamicResource BackgroundColor2}"
                          Foreground="{DynamicResource MainTextColor}"
                          BorderBrush="{DynamicResource BorderColor}"
                          DisplayMemberPath="TenNsx"/>
            </StackPanel>
        </Grid>

        <!-- Row 4: ĐVT và Bảo hành -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Đơn vị tính" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtDvt" Style="{StaticResource InputStyle}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Bảo hành (tháng)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtTgbh" Style="{StaticResource InputStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Row 5: Đơn giá bán và Số lượng tồn -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Đơn giá bán" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtDonGia" Style="{StaticResource InputStyle}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Số lượng tồn" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtSoLuong" Style="{StaticResource InputStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Row 6: Ngày nhập -->
        <TextBlock Text="Ngày nhập" Style="{StaticResource LabelStyle}"/>
        <DatePicker x:Name="DpNgayNhap" Margin="0,0,0,24" FontSize="13"
                    Background="{DynamicResource BackgroundColor2}"
                    Foreground="{DynamicResource MainTextColor}"
                    BorderBrush="{DynamicResource BorderColor}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Style="{StaticResource CancelBtnStyle}"
                    Margin="0,0,10,0" Click="BtnHuy_Click"/>
            <Button x:Name="BtnLuu" Content="Lưu" Style="{StaticResource PrimaryBtnStyle}"
                    Click="BtnLuu_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
