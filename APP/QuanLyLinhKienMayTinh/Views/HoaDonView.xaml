<Page x:Class="QuanLyLinhKienMayTinh.Views.HoaDonView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="1000"
      Title="Hóa Đơn"
      Background="{DynamicResource BackgroundColor}">

    <Page.Resources>
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
        </Style>
        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextColor}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="38,9,12,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ButtonColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SuccessBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#43a047"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2e7d32"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#e53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#b71c1c"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WarningBtnStyle" TargetType="Button" BasedOn="{StaticResource PrimaryBtnStyle}">
            <Setter Property="Background" Value="#fb8c00"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e65100"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SecondaryBgColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Text="Hóa Đơn" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Quản lý danh sách hóa đơn bán hàng" Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>
            <Button HorizontalAlignment="Right" Content="＋  Tạo hóa đơn mới"
                    Style="{StaticResource SuccessBtnStyle}" Padding="16,10"
                    Command="{Binding TaoHoaDonCommand}"/>
            <Button Content="Reset"
                    Background="Red" Foreground="White" Padding="16,10"
                    Command="{Binding ResetLocCommand}" Margin="695,0,158,0"/>
        </Grid>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundColor}" CornerRadius="10" Padding="14,10"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <TextBox Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding TuKhoanTimKiem, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="🔍" VerticalAlignment="Center" Margin="12,0,0,0"
                               IsHitTestVisible="False" Foreground="{DynamicResource SubTextColor}"/>
                </Grid>
                <ComboBox Grid.Column="1" Margin="0,0,10,0" Padding="10,8" FontSize="13"
                          BorderBrush="{DynamicResource BorderColor}" Foreground="{DynamicResource MainTextColor}" Background="Transparent"
                          ItemsSource="{Binding DanhSachTrangThai}"
                          SelectedItem="{Binding TrangThaiChon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>        

                <DatePicker Grid.Column="2" Margin="0,0,10,0" Foreground="{DynamicResource MainTextColor}" Background="Transparent"
                            SelectedDate="{Binding TuNgay}" FontSize="13"/>
                <DatePicker Grid.Column="3" Margin="0,0,10,0" Foreground="{DynamicResource MainTextColor}" Background="Transparent"
                            SelectedDate="{Binding DenNgay}" FontSize="13"/>
                <Button Grid.Column="4" Content="Lọc"
                        Style="{StaticResource PrimaryBtnStyle}"
                        Command="{Binding LocHoaDonCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BackgroundColor}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,0,12,0"
                    ClipToBounds="True">
                <DataGrid ItemsSource="{Binding DanhSachHoaDon}"
                          SelectedItem="{Binding HoaDonChon}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                          RowBackground="{DynamicResource BackgroundColor2}" AlternatingRowBackground="{DynamicResource BackgroundColor}"
                          FontSize="13" BorderThickness="0" SelectionMode="Single" Margin="3">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Mã HD" Binding="{Binding MaHoaDon}" Width="100"/>
                        <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKhachHang}" Width="*"/>
                        <DataGridTextColumn Header="Nhân viên" Binding="{Binding TenNhanVien}" Width="130"/>
                        <DataGridTextColumn Header="Ngày tạo" Binding="{Binding NgayTao, StringFormat=dd/MM/yyyy}" Width="110"/>
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTien, StringFormat={}{0:N0} ₫}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ButtonColor}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="0,0,8,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="Trạng thái" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,3" HorizontalAlignment="Center"
                                            Background="{Binding TrangThaiMauNen}">
                                        <TextBlock Text="{Binding TrangThai}" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding TrangThaiMauChu}"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource BackgroundColor}" CornerRadius="10"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource SecondaryBgColor}" Padding="16,12"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="4" CornerRadius="2" Background="{DynamicResource ButtonColor}" Margin="0,2,10,2"/>
                            <TextBlock Text="Chi Tiết Hóa Đơn" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16" Visibility="{Binding ChiTietVisibility}">

                            <Border Background="{DynamicResource SecondaryBgColor}" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Mã hóa đơn" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.MaHoaDon}"
                                                   HorizontalAlignment="Right" FontSize="13"
                                                   FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Ngày tạo" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.NgayTao, StringFormat=dd/MM/yyyy HH:mm}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Thanh toán" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.PhuongThucThanhToan}"
                                                   HorizontalAlignment="Right" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Trạng thái" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.TrangThai}"
                                                   HorizontalAlignment="Right" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#43a047"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="KHÁCH HÀNG" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,8"/>
                            <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,14">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Họ tên" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.TenKhachHang}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Số điện thoại" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.SoDienThoai}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="SẢN PHẨM" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubTextColor}" Margin="0,0,0,8"/>
                            <DataGrid ItemsSource="{Binding ChiTietSanPham}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserAddRows="False" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                                      BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                                      FontSize="12" Margin="0,0,0,14" Foreground="{DynamicResource MainTextColor}"
                                      RowBackground="Transparent" AlternatingRowBackground="{DynamicResource SecondaryBgColor}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tên" Binding="{Binding TenSanPham}" Width="*"/>
                                    <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="40"/>
                                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="0,0,4,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Hạn bảo hành" Binding="{Binding HanBaoHanhHienThi}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#e53e3e"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Padding" Value="8,0,0,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="{DynamicResource SecondaryBgColor}" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Tạm tính" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.TamTinh, StringFormat={}{0:N0} ₫}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource MainTextColor}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Giảm giá" FontSize="12" Foreground="{DynamicResource SubTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.GiamGia, StringFormat={}{0:N0} ₫}"
                                                   HorizontalAlignment="Right" FontSize="12" Foreground="#e53935"/>
                                    </Grid>
                                    <Separator Background="{DynamicResource BorderColor}" Margin="0,4"/>
                                    <Grid>
                                        <TextBlock Text="Tổng cộng" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                                        <TextBlock Text="{Binding HoaDonChon.TongTien, StringFormat={}{0:N0} ₫}"
                                                   HorizontalAlignment="Right" FontSize="15"
                                                   FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding ChuaChonHoaDonVisibility}">
                        <TextBlock Text="🧾" FontSize="36" HorizontalAlignment="Center"/>
                        <TextBlock Text="Chọn hóa đơn để xem chi tiết"
                                   FontSize="13" Foreground="{DynamicResource SubTextColor}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{DynamicResource SecondaryBgColor}" Padding="12"
                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Visibility="{Binding ChiTietVisibility}" CornerRadius="0,0,10,10">
                        <WrapPanel HorizontalAlignment="Center">
                            <Button Content="✏️ Sửa" Style="{StaticResource WarningBtnStyle}"
                                    Command="{Binding SuaHoaDonCommand}" Margin="4" Padding="12,8"/>
                            <Button Content="🖨️ In" Style="{StaticResource PrimaryBtnStyle}"
                                    Command="{Binding InHoaDonCommand}" Margin="4" Padding="12,8"/>
                            <Button Content="🗑️ Xóa" Style="{StaticResource DangerBtnStyle}"
                                    Command="{Binding XoaHoaDonCommand}" Margin="4" Padding="12,8"/>
                            <Button Content="💳  Thanh toán" Style="{StaticResource PrimaryBtnStyle}"
                                    Command="{Binding ThanhToanHoaDonCommand}" Padding="12,8" Width="213"
                                    Margin="4" Visibility="{Binding ThanhToanButtonVisibility}"/>
                        </WrapPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{DynamicResource BackgroundColor}" CornerRadius="10" Padding="16,12"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Margin="0,12,0,0">
            <UniformGrid Columns="4">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource SecondaryBgColor}" Margin="0,0,10,0">
                        <TextBlock Text="🧾" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TongSoHoaDon, StringFormat={}{0} hóa đơn}"
                                   FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ButtonColor}"/>
                        <TextBlock Text="Tổng hóa đơn" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#e8f5e9" Margin="0,0,10,0">
                        <TextBlock Text="💰" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding TongDoanhThu, StringFormat={}{0:N0} ₫}"
                                   FontSize="13" FontWeight="Bold" Foreground="#43a047"/>
                        <TextBlock Text="Doanh thu" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#e3f2fd" Margin="0,0,10,0">
                        <TextBlock Text="✅" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SoHoaDonDaThanhToan, StringFormat={}{0} hóa đơn}"
                                   FontSize="13" FontWeight="Bold" Foreground="#2196f3"/>
                        <TextBlock Text="Đã thanh toán" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#fff3e0" Margin="0,0,10,0">
                        <TextBlock Text="⏳" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SoHoaDonChoXuLy, StringFormat={}{0} hóa đơn}"
                                   FontSize="13" FontWeight="Bold" Foreground="#fb8c00"/>
                        <TextBlock Text="Chưa thanh toán" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                    </StackPanel>
                </StackPanel>
            </UniformGrid>
        </Border>
    </Grid>
</Page>