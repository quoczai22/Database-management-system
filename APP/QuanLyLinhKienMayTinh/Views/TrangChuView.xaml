<Page x:Class="QuanLyLinhKienMayTinh.Views.TrangChuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="1000"
      Title="Trang Chủ"
      Background="{DynamicResource BackgroundColor}">
    <Page.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChartCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundColor}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.07" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainTextColor}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10,10,10,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="220"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="6,0,0,16">
                <TextBlock Text="Tổng quan hệ thống" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                <TextBlock Text="Xem nhanh thống kê và dữ liệu hệ thống" FontSize="13" Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
            </StackPanel>

            <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,4">

                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10"
                                Background="#e8eaf6" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Icon:PackIconMaterial Kind="AccountTie" Foreground="#3f51b5"
                                                   Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TongNV}" FontSize="26"
                                   FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Grid.Row="2" Text="Nhân Viên" FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10"
                                Background="#e3f2fd" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Icon:PackIconMaterial Kind="AccountGroupOutline" Foreground="#2196f3"
                                                   Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TongKH}" FontSize="26"
                                   FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Grid.Row="2" Text="Khách Hàng" FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10"
                                Background="#f3e5f5" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Icon:PackIconMaterial Kind="Memory" Foreground="#9c27b0"
                                                   Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TongLK}" FontSize="26"
                                   FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Grid.Row="2" Text="Linh Kiện" FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10"
                                Background="#fff3e0" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Icon:PackIconMaterial Kind="TagMultiple" Foreground="#ff9800"
                                                   Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TongLoaiLK}" FontSize="26"
                                   FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Grid.Row="2" Text="Loại Linh Kiện" FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="10"
                                Background="#e8f5e9" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <Icon:PackIconMaterial Kind="ReceiptOutline" Foreground="#4caf50"
                                                   Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Row="1" Text="{Binding TongHD}" FontSize="26"
                                   FontWeight="Bold" Foreground="{DynamicResource MainTextColor}"/>
                        <TextBlock Grid.Row="2" Text="Hóa Đơn" FontSize="12"
                                   Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                    </Grid>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Style="{StaticResource ChartCardStyle}" Margin="6,6,6,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="4" CornerRadius="2" Background="#009688" Margin="0,2,10,2"/>
                        <StackPanel>
                            <TextBlock Text="Thống kê" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="14" Margin="0,0,6,0"
                                Background="{DynamicResource SecondaryBgColor}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Giá trị tồn kho theo loại" FontSize="12"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding DanhSachLoaiLinhKien}"
                                              SelectedItem="{Binding LoaiLinhKienDangChon}"
                                              DisplayMemberPath="TenLoai"
                                              Height="32"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GiaTriTonKhoTheoLoai, StringFormat={}{0:N0} đ}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource ButtonColor}"/>
                                    <TextBlock Text="Giá trị tồn kho theo loại" FontSize="11"
                                               Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Padding="14" Margin="6,0,0,0"
                                Background="{DynamicResource SecondaryBgColor}" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tổng số lượng nhập theo linh kiện" FontSize="12"
                                               FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"
                                               Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding DanhSachLinhKien}"
                                              SelectedItem="{Binding LinhKienDangChon}"
                                              DisplayMemberPath="TenLk"
                                              Height="32"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TongSoLuongNhapTheoLinhKien, StringFormat={}{0:N0}}"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource ButtonColor}"/>
                                    <TextBlock Text="Tổng số lượng nhập" FontSize="11"
                                               Foreground="{DynamicResource SubTextColor}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="3" Height="240" Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ChartCardStyle}" Margin="6,6,4,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" CornerRadius="2" Background="{DynamicResource ButtonColor}" Margin="0,2,10,2"/>
                            <StackPanel>
                                <TextBlock Text="Biểu đồ Doanh thu" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                                <TextBlock Text="Tổng doanh thu 12 tháng (VNĐ)" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                            </StackPanel>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding DoanhThu}" Foreground="{DynamicResource MainTextColor}">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Tháng" Labels="{Binding Labels}" Foreground="{DynamicResource MainTextColor}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Số tiền" LabelFormatter="{Binding Formatter}" Foreground="{DynamicResource MainTextColor}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ChartCardStyle}" Margin="4,6,6,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" CornerRadius="2" Background="#9c27b0" Margin="0,2,10,2"/>
                            <StackPanel>
                                <TextBlock Text="Nhân viên theo chức vụ" FontSize="14"
                                           FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                                <TextBlock Text="Phân bổ nhân sự" FontSize="11" Foreground="{DynamicResource SubTextColor}"/>
                            </StackPanel>
                        </StackPanel>

                        <lvc:PieChart Grid.Row="1" Series="{Binding ChucVu}"
                                      InnerRadius="30" LegendLocation="Bottom" Foreground="{DynamicResource MainTextColor}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource ChartCardStyle}" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="4" CornerRadius="2" Background="#4caf50" Margin="0,2,10,2"/>
                        <StackPanel>
                            <TextBlock Text="Top khách hàng mua nhiều nhất" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MainTextColor}"/>
                        </StackPanel>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DanhSachTopKhachHang}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False"
                              Background="Transparent" BorderThickness="0"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                              RowBackground="Transparent" AlternatingRowBackground="{DynamicResource SecondaryBgColor}"
                              Foreground="{DynamicResource MainTextColor}"
                              FontSize="13">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource ButtonColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ButtonTextColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã khách hàng" Binding="{Binding MaKh}" Width="200"/>
                            <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKh}" Width="300"/>
                            <DataGridTextColumn Header="Tổng tiền đã thanh toán" Binding="{Binding TongTien, StringFormat={}{0:N0}}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
