<Window x:Class="QuanLyLinhKienMayTinh.LoginApp"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ứng dụng đăng nhập"
        Height="600"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#2a5298">
    <Grid>
        <Ellipse Width="500" Height="500" VerticalAlignment="Bottom" Fill="#80CCFF" Margin="50,0,-200,0" Opacity="0.6"/>
        <Ellipse Width="300" Height="300" VerticalAlignment="Bottom" Fill="#83C2FF" Margin="-450,0,0,30" Opacity="0.3"/>
        <Ellipse Width="400" Height="400" VerticalAlignment="Bottom" Fill="#84C3FF" Margin="-320,0,-120,0" Opacity="0.6"/>
        <Ellipse Width="250" Height="250" VerticalAlignment="Bottom" Fill="#81C2FF" Margin="-380,0,-120,0"/>
        <Ellipse Width="400" Height="400" VerticalAlignment="Bottom" Fill="#87C5FF" Margin="280,0,-70,0" Opacity="0.8"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Nhóm 6" FontSize="28" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock x:Name="txtMessage" Text="Vui lòng đăng ký để tiếp tục" FontSize="16" Foreground="GhostWhite" Margin="0,10,0,20" HorizontalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid Width="300">

                    <StackPanel x:Name="SignUpPanel">
                        <TextBlock Text="Đăng ký" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Tên đăng nhập"/>
                        <TextBox x:Name="suUsername"/>
                        <TextBlock Text="Mật khẩu"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="suPassword"/>
                            <TextBox x:Name="suPasswordVisible" Visibility="Collapsed"/>
                            <Button Grid.Column="1" Content="🎱" Style="{StaticResource EyeButtonStyle}" Click="ToggleSuPassword_Click"/>
                        </Grid>
                        <TextBlock Text="Xác nhận mật khẩu"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="suConfirmPassword"/>
                            <TextBox x:Name="suConfirmPasswordVisible" Visibility="Collapsed"/>
                            <Button Grid.Column="1" Content="🎱" Style="{StaticResource EyeButtonStyle}" Click="ToggleSuConfirmPassword_Click"/>
                        </Grid>
                        <Button Content="Đăng ký" Background="#4CAF50" Foreground="White" Click="SignUp_Click"/>
                        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Run Text="Đã có tài khoản? "/>
                            <Hyperlink Click="ShowLogin_Click">Đăng nhập</Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                        <TextBlock Text="Đăng nhập" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Tên đăng nhập"/>
                        <TextBox x:Name="liUsername"/>
                        <TextBlock Text="Mật khẩu"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox x:Name="liPassword"/>
                            <TextBox x:Name="liPasswordVisible" Visibility="Collapsed"/>
                            <Button Grid.Column="1" Content="🎱" Style="{StaticResource EyeButtonStyle}" Click="ToggleLiPassword_Click"/>
                        </Grid>
                        <Button Content="Đăng nhập" Background="#2196F3" Foreground="White" Click="Login_Click"/>
                        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Run Text="Chưa có tài khoản? "/>
                            <Hyperlink Click="ShowSignUp_Click">Đăng ký</Hyperlink>
                        </TextBlock>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
